# Plaid credentials (https://dashboard.plaid.com/developers/keys)
# Trial plan uses PRODUCTION keys (development env was removed June 2024).
PLAID_CLIENT_ID=
PLAID_SECRET_SANDBOX=
PLAID_SECRET_PRODUCTION=
# Optional: single secret override for the selected PLAID_ENV
# PLAID_SECRET=

# sandbox = fake banks for testing
# production = real banks / Plaid Trial (up to 10 Items)
PLAID_ENV=sandbox

# Comma-separated. "transactions" is required for bank sync.
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
PLAID_LANGUAGE=en

# Days of history to request on first Item init (1–730). Default 90 if unset.
# PLAID_TRANSACTIONS_DAYS_REQUESTED=730

# Actual Budget server
ACTUAL_SERVER_URL=https://your-actual-server.example
ACTUAL_SERVER_PASSWORD=
# Optional: end-to-end encryption password for the budget file
ACTUAL_SERVER_ENCRYPTION_PASSWORD=

# Local Link helper server
APP_PORT=3000
APP_BIND_ADDRESS=127.0.0.1

# Public URL used for OAuth institutions. Must be HTTPS (not localhost) for many US banks.
# Register the same URL as Allowed redirect URI in the Plaid dashboard if required.
APP_URL=http://localhost

# Optional Pushover notifications after import
# PUSHOVER_TOKEN=
# PUSHOVER_USER_KEY=
